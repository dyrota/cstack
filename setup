#!/usr/bin/env bash
set -euo pipefail

# cstack setup script
# Installs cstack agents, prompts, and copilot instructions into your project or globally.
#
# VS Code skill/agent discovery paths:
#   Project-local:  .agents/skills/  and  .github/agents/
#   Global:         ~/.vscode/agents/skills/  and  ~/.github/agents/

CSTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL=false

usage() {
  echo "Usage: ./setup [--local]"
  echo ""
  echo "  --local    Install into current project (.agents/skills/ and .github/agents/)"
  echo "             Default: install globally (~/.vscode/agents/skills/ and ~/.github/agents/)"
  exit 0
}

for arg in "$@"; do
  case $arg in
    --local) LOCAL=true ;;
    --help|-h) usage ;;
  esac
done

if [ "$LOCAL" = true ]; then
  # Find the project root — the nearest .git repo that isn't cstack itself
  PROJECT_ROOT=""
  search_dir="$(pwd)"
  while [ "$search_dir" != "/" ]; do
    if [ -d "$search_dir/.git" ]; then
      # Skip if this is the cstack repo itself
      if [ "$search_dir" != "$CSTACK_DIR" ]; then
        PROJECT_ROOT="$search_dir"
        break
      fi
    fi
    search_dir="$(dirname "$search_dir")"
  done
  if [ -z "$PROJECT_ROOT" ]; then
    echo "⚠️  Could not find a parent git repo. Defaulting to two levels up from cstack."
    PROJECT_ROOT="$(cd "$CSTACK_DIR/../.." && pwd)"
  fi
  SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
  AGENTS_DIR="$PROJECT_ROOT/.github/agents"
  PROMPTS_DIR="$PROJECT_ROOT/.github/prompts"
  INSTRUCTIONS_FILE="$PROJECT_ROOT/.github/copilot-instructions.md"
  echo "📦 Installing cstack locally into $PROJECT_ROOT/"else
  SKILLS_DIR="$HOME/.agents/skills"
  AGENTS_DIR="$HOME/.github/agents"
  PROMPTS_DIR="$HOME/.github/prompts"
  INSTRUCTIONS_FILE="$HOME/.github/copilot-instructions.md"
  echo "📦 Installing cstack globally into ~/.agents/skills/ and ~/.github/"
fi

# Create directories
mkdir -p "$SKILLS_DIR"
mkdir -p "$AGENTS_DIR"
mkdir -p "$PROMPTS_DIR"

# Copy skills (each skill is a directory with SKILL.md)
# Skills live in assets/skills/ (v1.1+), fall back to skills/ (v0.1 layout)
SKILLS_SRC="$CSTACK_DIR/assets/skills"
[ -d "$SKILLS_SRC" ] || SKILLS_SRC="$CSTACK_DIR/skills"

echo "→ Copying skills..."
for skill_dir in "$SKILLS_SRC"/*/; do
  skill_name="$(basename "$skill_dir")"
  mkdir -p "$SKILLS_DIR/$skill_name"
  cp -r "$skill_dir"* "$SKILLS_DIR/$skill_name/"
done

# Copy agents
# Agents live in assets/agents/ (v1.1+), fall back to agents/ (v0.1 layout)
AGENTS_SRC="$CSTACK_DIR/assets/agents"
[ -d "$AGENTS_SRC" ] || AGENTS_SRC="$CSTACK_DIR/agents"

echo "→ Copying agents..."
cp -r "$AGENTS_SRC/"*.agent.md "$AGENTS_DIR/"

# Copy prompts (if any exist)
PROMPTS_SRC="$CSTACK_DIR/assets/prompts"
[ -d "$PROMPTS_SRC" ] || PROMPTS_SRC="$CSTACK_DIR/prompts"

if [ -d "$PROMPTS_SRC" ] && [ "$(ls -A "$PROMPTS_SRC" 2>/dev/null)" ]; then
  echo "→ Copying prompts..."
  cp -r "$PROMPTS_SRC/"* "$PROMPTS_DIR/"
fi

# Optionally append cstack block to copilot-instructions.md
CSTACK_BLOCK="$CSTACK_DIR/.github/copilot-instructions.md"

if [ -f "$CSTACK_BLOCK" ]; then
  if [ -f "$INSTRUCTIONS_FILE" ]; then
    if grep -q "# BEGIN cstack" "$INSTRUCTIONS_FILE" 2>/dev/null; then
      echo "→ copilot-instructions.md already contains cstack block, skipping."
    else
      echo "→ Appending cstack block to copilot-instructions.md..."
      {
        echo ""
        echo "# BEGIN cstack"
        cat "$CSTACK_BLOCK"
        echo "# END cstack"
      } >> "$INSTRUCTIONS_FILE"
    fi
  else
    echo "→ Creating copilot-instructions.md..."
    mkdir -p "$(dirname "$INSTRUCTIONS_FILE")"
    {
      echo "# BEGIN cstack"
      cat "$CSTACK_BLOCK"
      echo "# END cstack"
    } > "$INSTRUCTIONS_FILE"
  fi
fi

echo ""
echo "✅ cstack installed successfully!"
echo ""
echo "Skills installed to: $SKILLS_DIR"
echo "Agents installed to: $AGENTS_DIR"
echo ""
echo "Available skills:"
echo "  /plan        Generate implementation plan"
echo "  /implement   Execute PLAN.md step-by-step"
echo "  /review      Staff-level code review"
echo "  /test        Run tests and write coverage"
echo "  /ship        Commit and open PR"
echo "  /debug       Systematic root-cause debugging"
echo ""
echo "Available agents:"
echo "  @planner     Read-only planning"
echo "  @reviewer    Code review (reports only)"
echo "  @implementer Full-edit implementation"
echo "  @tester      Tester and test coverage"
echo ""
echo "Workflow: /plan → [implement] → /review → /test → /ship"
